AUTH_API_REGION=us-central1

# WhatsApp Cloud API
# Your business sending number can be +919207037558, but the API needs the
# corresponding Meta access token and phone number ID, not just the raw number.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en

# SMTP / Email OTP
# Use 22b827@nssce.ac.in as the sender only if your mail provider allows SMTP
# sign-in for that mailbox and you have the host, username, and password.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=22b827@nssce.ac.in
SMTP_PASS=
SMTP_FROM=22b827@nssce.ac.in

# Twilio SMS
# Free trial accounts can only send SMS to phone numbers verified in Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
